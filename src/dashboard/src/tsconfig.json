{
  "compilerOptions": {
    "paths": {
      "@core/*": ["../../core/*"],
      "@cli/*": ["../../cli/*"]
    },
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.dashboard.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["../../dashboard/src"]
}
