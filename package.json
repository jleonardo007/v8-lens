{
  "name": "v8-lens",
  "version": "0.2.0",
  "description": "Real-time observability for Node.js processes via the Chrome DevTools Protocol.",
  "main": "./dist/cli/index.js",
  "type": "module",
  "bin": {
    "v8-lens": "./dist/cli/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/dashboard/**",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "v8",
    "nodejs",
    "observability",
    "profiler",
    "cdp",
    "chrome-devtools-protocol",
    "heap",
    "memory-leak",
    "cpu-profiling",
    "flame-graph",
    "event-loop",
    "garbage-collector",
    "debugging",
    "performance",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jleonardo007/v8-lens.git"
  },
  "bugs": {
    "url": "https://github.com/jleonardo007/v8-lens/issues"
  },
  "homepage": "https://github.com/jleonardo007/v8-lens#readme",
  "author": "Leonardo Bravo (https://github.com/jleonardo007)",
  "license": "MIT",
  "imports": {
    "#core/*": "./src/core/*.ts",
    "#cli/*": "./src/cli/*.ts"
  },
  "scripts": {
    "start": "tsx src/cli/index.ts",
    "build:cli": "tsc",
    "build:dashboard": "vite build --config src/dashboard/vite.config.ts",
    "build": "pnpm build:cli && pnpm build:dashboard",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run lint:check && npm run format:check",
    "prepare": "husky"
  },
  "dependencies": {
    "inquirer": "^14.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/inquirer": "9.0.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@types/yargs": "17.0.35",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-unicorn": "64.0.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
