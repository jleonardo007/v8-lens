{
  "compilerOptions": {
    "target": "es2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2024"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@core/*": ["./src/core/*"],
      "@cli/*": ["./src/cli/*"]
    }
  },
  "include": ["src/cli/**/*", "src/core/**/*"],
  "exclude": ["node_modules", "dist", "src/dashboard"]
}
