{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@core/*": ["./src/core/*"],
      "@cli/*": ["./src/cli/*"],
      "@dashboard/*": ["./src/dashboard/*"]
    }
  },
  "include": ["src/cli/**/*", "src/core/**/*"],
  "exclude": ["node_modules", "dist", "src/dashboard"]
}
